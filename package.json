{
  "name": "sketch-forge",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "prettier": "^3.7.4",
    "turbo": "^2.9.10",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "arctic": "^3.7.0",
    "oslo": "^1.2.1",
    "zustand": "^5.0.14"
  }
}
